# Provider 选择
# 当前建议值：
# - anthropic-compatible
# - openai-responses-compatible
CLAUDE_CODE_THY_PROVIDER=anthropic-compatible

# 全局默认模型。
# 后续扩展第二种 LLM 时，建议统一优先读取这个值；为空时再回退到各 provider 自己的默认模型。
CLAUDE_CODE_THY_MODEL=

# Anthropic 兼容 API 配置
# 二选一：标准 API Key 或 Bearer Token
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=

# 如果使用兼容 Anthropic 的第三方服务，可以改成对应网关地址
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Anthropic 兼容 provider 的默认模型
ANTHROPIC_MODEL=glm-4.5

# OpenAI Responses API 兼容配置
# 调用方式参考仓库根目录的 test_gpt.py
OPENAI_RESPONSES_API_KEY=
OPENAI_RESPONSES_BASE_URL=https://gmn.chuangzuoli.com
OPENAI_RESPONSES_MODEL=gpt-5.4
OPENAI_RESPONSES_REASONING_EFFORT=xhigh
OPENAI_RESPONSES_ENABLE_STREAM=false

# 通用 API 超时，单位毫秒
API_TIMEOUT_MS=600000

# 单次回复最大 token 数
CLAUDE_CODE_THY_MAX_TOKENS=4096

# 会话数据目录，可选
# CLAUDE_CODE_THY_HOME=/absolute/path/to/claude-code-thy-data
