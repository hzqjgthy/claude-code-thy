Screen {
    background: #0b0f17;
    color: #f5f7fa;
}

#root {
    layout: vertical;
    width: 100%;
    height: 100%;
}

#hero {
    height: auto;
    margin: 1 2 0 2;
}

#chat_surface {
    height: 1fr;
    margin: 0 2;
    padding: 0 1 1 1;
}

#message_list {
    width: 100%;
    height: auto;
}

.message {
    width: 100%;
    height: auto;
    padding: 0 0 1 0;
}

#resume_hint {
    height: auto;
    margin: 0 1;
    color: #9aa4b2;
}

#tool_status {
    height: auto;
    margin: 0 1;
    color: #9aa4b2;
}

#input_row {
    layout: horizontal;
    height: 3;
    margin: 0;
    padding: 0 1 0 0;
}

#prompt_glyph {
    width: 3;
    content-align: center middle;
    color: #f5f7fa;
    text-style: bold;
}

#prompt_input {
    width: 1fr;
    border: none;
    background: transparent;
    color: #f5f7fa;
}
